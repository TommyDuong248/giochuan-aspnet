@model GioChuanGiangDay.ViewModels.TongHopGioChuanViewModel?

@{
    ViewData["Title"] = "Tổng hợp giờ chuẩn";
}

<div class="container mt-4">
    <h2>Tổng hợp giờ chuẩn</h2>

    <form method="get" asp-action="Index" class="row g-3 mb-4">
        <div class="col-md-5">
            <label class="form-label">Giảng viên</label>
            <select name="giangVienId" asp-items="ViewBag.GiangVienId" class="form-control">
                <option value="">-- Chọn giảng viên --</option>
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label">Năm học</label>
            <input name="namHoc" value="@ViewBag.NamHoc" class="form-control" />
        </div>

        <div class="col-md-4 d-flex align-items-end">
            <button type="submit" class="btn btn-primary me-2">Xem tổng hợp</button>
            <a asp-controller="HoatDongQuyDoi" asp-action="Index" class="btn btn-secondary">Hoạt động quy đổi</a>
        </div>
    </form>

    @if (Model != null)
    {
        if (!Model.DaCauHinhDinhMuc)
        {
            <div class="alert alert-warning">
                @Model.GhiChu
            </div>
        }

        <h4>@Model.HoTen - @Model.MaGiangVien</h4>
        <p>Năm học: <strong>@Model.NamHoc</strong></p>

        <table class="table table-bordered">
            <thead>
                <tr>
                    <th>Nội dung</th>
                    <th class="text-end">Số giờ</th>
                </tr>
            </thead>
            <tbody>
                <tr class="table-primary">
                    <td colspan="2"><strong>I. GIỜ GIẢNG DẠY</strong></td>
                </tr>
                <tr>
                    <td>Định mức giờ giảng dạy phải hoàn thành</td>
                    <td class="text-end">@Model.GioChuanGiangDay</td>
                </tr>
                <tr>
                    <td>Giờ giảng dạy trực tiếp</td>
                    <td class="text-end">@Model.GioGiangDayTrucTiep</td>
                </tr>
                <tr>
                    <td>Giờ hướng dẫn sinh viên / thực tập / khóa luận / giảng dạy khác</td>
                    <td class="text-end">@Model.GioHuongDanVaGiangDayKhac</td>
                </tr>
                <tr>
                    <td>Giờ hội đồng liên quan giảng dạy</td>
                    <td class="text-end">@Model.GioHoiDong</td>
                </tr>
                <tr>
                    <td><strong>Tổng giờ giảng dạy quy đổi</strong></td>
                    <td class="text-end"><strong>@Model.TongGioGiangDay</strong></td>
                </tr>
                <tr>
                    <td><strong>Chênh lệch giờ giảng dạy</strong></td>
                    <td class="text-end">
                        @if (Model.ChenhLechGiangDay >= 0)
                        {
                            <span class="text-success"><strong>Dư @Model.ChenhLechGiangDay giờ</strong></span>
                        }
                        else
                        {
                            <span class="text-danger"><strong>Thiếu @Math.Abs(Model.ChenhLechGiangDay) giờ</strong></span>
                        }
                    </td>
                </tr>

                <tr class="table-success">
                    <td colspan="2"><strong>II. NGHIÊN CỨU KHOA HỌC</strong></td>
                </tr>
                <tr>
                    <td>Định mức giờ NCKH phải hoàn thành</td>
                    <td class="text-end">@Model.GioChuanNckh</td>
                </tr>
                <tr>
                    <td>Tổng giờ NCKH đã thực hiện</td>
                    <td class="text-end">@Model.GioNckh</td>
                </tr>
                <tr>
                    <td><strong>Chênh lệch giờ NCKH</strong></td>
                    <td class="text-end">
                        @if (Model.ChenhLechNckh >= 0)
                        {
                            <span class="text-success"><strong>Dư @Model.ChenhLechNckh giờ</strong></span>
                        }
                        else
                        {
                            <span class="text-danger"><strong>Thiếu @Math.Abs(Model.ChenhLechNckh) giờ</strong></span>
                        }
                    </td>
                </tr>

                <tr class="table-warning">
                    <td colspan="2"><strong>III. NHIỆM VỤ KHÁC</strong></td>
                </tr>
                <tr>
                    <td>Tổng giờ nhiệm vụ khác</td>
                    <td class="text-end">@Model.GioNhiemVuKhac</td>
                </tr>

                <tr class="table-dark">
                    <td><strong>TỔNG TẤT CẢ GIỜ QUY ĐỔI</strong></td>
                    <td class="text-end"><strong>@Model.TongTatCaGioQuyDoi</strong></td>
                </tr>
            </tbody>
        </table>
    }
    else
    {
        <div class="alert alert-info">
            Chọn giảng viên và năm học để xem tổng hợp giờ chuẩn.
        </div>
    }
</div>